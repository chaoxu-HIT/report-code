# 如果是列表，取第一个元素（单输出模型）
if isinstance(shap_values, list) and len(shap_values) == 1:
    shap_values = shap_values[0]

# 确保SHAP值是2D数组
if len(np.array(shap_values).shape) > 2:
    shap_values = np.squeeze(shap_values)
    
# 打印最终形状
