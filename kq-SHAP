print("创建SHAP瀑布图...")

# 选择几个样本进行瀑布图可视化
waterfall_samples = min(10, len(sample_data))  # 控制生成的样本数量
waterfall_data = []  # 用于存储瀑布图数据

for i in range(waterfall_samples):
    try:
        plt.figure(figsize=(12, 10))
        
        # 为瀑布图创建更完整的标题，包含样本索引和预测值
