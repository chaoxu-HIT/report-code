        with torch.no_grad():
            prediction = model(torch.tensor(sample_data[i:i+1], dtype=torch.float32).to(device)).item()
        
        # 创建瀑布图
        # 使用shap.Explanation对象来创建瀑布图
        shap.plots.waterfall(
            shap.Explanation(
                values=shap_values[i],
                base_values=explainer.expected_value,
                data=sample_data[i],
                feature_names=feature_names_list
            ),
            show=False,
            max_display=len(feature_names_list)  # 显示所有特征
        )
        
        # 设置标题
        plt.title(f'SHAP 瀑布图 - 样本 {sample_idx} (预测值: {prediction:.4f})', fontsize=14, fontweight='bold')
        
        # 调整图形尺寸和边距
        plt.tight_layout()
        plt.savefig(os.path.join(shap_output_dir, f'shap_waterfall_sample_{sample_idx}.png'), dpi=300, bbox_inches='tight')
        plt.close()
        
        # 收集瀑布图数据用于保存到Excel
        sample_waterfall_data = {
            'sample_index': sample_idx,
            'base_value': explainer.expected_value,
            'prediction': prediction
        }
        
        # 添加每个特征的SHAP值和原始特征值
        for j, feature in enumerate(feature_names_list):
            sample_waterfall_data[f'SHAP_{feature}'] = shap_values[i, j]
            sample_waterfall_data[f'Value_{feature}'] = sample_data[i, j]
            
        # 计算特征累积贡献
        cumulative_effect = explainer.expected_value
        sample_waterfall_data['starting_value'] = cumulative_effect
        
        # 按SHAP值绝对值排序的特征索引
        sorted_indices = np.argsort(-np.abs(shap_values[i]))
        
        # 添加累积效应数据（按SHAP绝对值从大到小）
        for rank, j in enumerate(sorted_indices):
            feature = feature_names_list[j]
            feature_effect = shap_values[i, j]
            cumulative_effect += feature_effect
            sample_waterfall_data[f'cumulative_after_{feature}'] = cumulative_effect
            sample_waterfall_data[f'rank_{rank+1}_feature'] = feature
            sample_waterfall_data[f'rank_{rank+1}_effect'] = feature_effect
        
        waterfall_data.append(sample_waterfall_data)
        
        print(f"成功创建样本 {sample_idx} 的瀑布图")
    except Exception as e:
        print(f"创建样本 {i} 的瀑布图时出错: {e}")

# 保存瀑布图数据到Excel
try:
    # 如果有收集到数据
    if waterfall_data:
        waterfall_df = pd.DataFrame(waterfall_data)
        waterfall_df.to_excel(os.path.join(shap_output_dir, 'shap_waterfall_data.xlsx'), index=False)
        print("成功保存瀑布图数据到Excel")
    else:
