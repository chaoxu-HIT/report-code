# ====================== 6.6 计算SHAP值与原始特征的相关性 ======================
# 计算每个特征的原始值与其SHAP值之间的相关性
try:
    X_orig_sample = df[final_features].values
    correlation_data = []
    
    # 参数说明:
    # - Feature: 特征名称
    # - SHAP_Feature_Correlation: 特征值与SHAP值的相关系数
    # - SHAP_Feature_Correlation_abs: 相关系数的绝对值
    for i, feature in enumerate(feature_names_list):
        corr = np.corrcoef(X_orig_sample[:, i], shap_values[:, i])[0, 1]
        correlation_data.append({
            'Feature': feature,
            'SHAP_Feature_Correlation': corr,
            'SHAP_Feature_Correlation_abs': abs(corr)
        })
    
    # 创建DataFrame并按相关性绝对值排序
    corr_df = pd.DataFrame(correlation_data)
    corr_df = corr_df.sort_values('SHAP_Feature_Correlation_abs', ascending=False)
    corr_df.to_excel(os.path.join(shap_output_dir, 'shap_feature_correlations_all_data.xlsx'), index=False)
    print("成功创建SHAP特征相关性Excel文件 (所有数据点)")
    
except Exception as e:
    print(f"计算SHAP值相关性时出错: {e}")

