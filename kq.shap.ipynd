   "source": [
    "import pandas as pd\n",
    "from sklearn.model_selection import (cross_val_score, KFold, \n",
    "                                     RandomizedSearchCV, train_test_split)\n",
    "from sklearn.linear_model import (LinearRegression, Ridge, Lasso, ElasticNet, \n",
    "                                   HuberRegressor, BayesianRidge, LassoCV, RidgeCV, ElasticNetCV)\n",
    "from sklearn.ensemble import (RandomForestRegressor, GradientBoostingRegressor, \n",
    "                              ExtraTreesRegressor, BaggingRegressor, \n",
    "                              StackingRegressor, VotingRegressor, AdaBoostRegressor)\n",
    "from sklearn.neural_network import MLPRegressor\n",
    "from sklearn.svm import SVR\n",
    "from sklearn.tree import DecisionTreeRegressor\n",
    "from lightgbm import LGBMRegressor\n",
    "from xgboost import XGBRegressor\n",
    "from catboost import CatBoostRegressor\n",
    "from sklearn.pipeline import make_pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics import mean_absolute_error, r2_score\n",
    "from sklearn.feature_selection import RFECV\n",
    "import numpy as np\n",
    "\n",
    "# 加载数据集\n",
    "file_path = r'D:\\文成数据库\\Nb-Si数据库12.24-成分-性能.xlsx'\n",
    "df = pd.read_excel(file_path)\n",
    "\n",
    "# 提取特征和目标值\n",
    "X = df[['Nb', 'Si', 'Ti', 'Al', 'Cr', 'Hf', 'Zr', 'Mo', 'Fe', 'B', 'Y', 'V',\n",
    "    'W', 'Zn', 'Mg', 'P', 'Ta', 'Co', 'Sc', 'Ni', 'Ge', 'Sn', 'C', 'Gd',\n",
    "    'Ru', 'Mn', 'N', 'Re', 'Sm', 'La', 'Ho', 'Sr', 'Ce', 'Ga',\n",
    "    'VEC', 'x', 'Δx', 'ΔHmix', 'ΔSmix', 'ΔG', 'Tm', 'ΔTm', 'ρ', 'r',\n",
    "    'am', 'Δa', 'δ', 'Ω', 'λ']]\n",
    "y = df['KQ']\n",
    "\n",
    "# 特征选择（使用交叉验证选择最优特征数）\n",
    "selector = RFECV(estimator=LinearRegression(), cv=5)\n",
    "X_selected = selector.fit_transform(X, y)\n",
    "\n",
    "# 定义表现优秀的基本模型（进一步降低复杂性，增加正则化）\n",
    "base_models = [\n",
    "    ('Random Forest', RandomForestRegressor(max_depth=15, n_estimators=200, min_samples_leaf=2, min_samples_split=5)),\n",
    "    ('Gradient Boosting', GradientBoostingRegressor(n_estimators=200, max_depth=6, learning_rate=0.05, subsample=0.8)),\n",
    "    ('Extra Trees', ExtraTreesRegressor(max_depth=12, n_estimators=200, min_samples_leaf=3, min_samples_split=5)),\n",
    "    ('Bagging', BaggingRegressor(n_estimators=100, max_samples=0.8, max_features=0.8)),\n",
    "    ('LightGBM', LGBMRegressor(n_estimators=200, reg_alpha=2.0, reg_lambda=2.0, learning_rate=0.05)),\n",
    "    ('XGBoost', XGBRegressor(n_estimators=200, max_depth=8, reg_alpha=2.0, reg_lambda=2.0, learning_rate=0.05, subsample=0.8)),\n",
    "    ('CatBoost', CatBoostRegressor(silent=True, depth=7, l2_leaf_reg=4.0, learning_rate=0.05)),\n",
    "    ('AdaBoost', AdaBoostRegressor(n_estimators=200, learning_rate=0.05)),\n",
    "    ('SVR', SVR(C=1.0, epsilon=0.1)),\n",
    "    ('Decision Tree', DecisionTreeRegressor(max_depth=10, min_samples_leaf=4)),\n",
    "    ('MLP Regressor', MLPRegressor(hidden_layer_sizes=(100, 100), max_iter=500, learning_rate_init=0.01)),\n",
    "    ('Bayesian Ridge', BayesianRidge()),\n",
    "    ('ElasticNet', ElasticNet(alpha=0.1, l1_ratio=0.5))\n",
    "]\n",
    "\n",
    "# 堆叠模型（减少基础模型数量，修改最终估计器为 RidgeCV）\n",
    "stacking_model = StackingRegressor(\n",
    "    estimators=[\n",
    "        ('Random Forest', RandomForestRegressor(max_depth=15, n_estimators=200, min_samples_leaf=2, min_samples_split=5)),\n",
    "        ('Gradient Boosting', GradientBoostingRegressor(n_estimators=200, max_depth=6, learning_rate=0.05, subsample=0.8)),\n",
    "        ('LightGBM', LGBMRegressor(n_estimators=200, reg_alpha=2.0, reg_lambda=2.0, learning_rate=0.05))\n",
    "    ],\n",
    "    final_estimator=RidgeCV()\n",
    ")\n",
    "\n",
    "# 投票回归器（为表现较好的模型赋予更高权重）\n",
    "voting_model = VotingRegressor(\n",
    "    estimators=[\n",
    "        ('Random Forest', RandomForestRegressor(max_depth=15, n_estimators=200, min_samples_leaf=2, min_samples_split=5)),\n",
    "        ('Gradient Boosting', GradientBoostingRegressor(n_estimators=200, max_depth=6, learning_rate=0.05, subsample=0.8)),\n",
    "        ('LightGBM', LGBMRegressor(n_estimators=200, reg_alpha=2.0, reg_lambda=2.0, learning_rate=0.05))\n",
    "    ],\n",
    "    weights=[3, 3, 2]\n",
    ")\n",
    "\n",
    "# 将所有模型添加到模型字典中\n",
    "models = {name: model for name, model in base_models}\n",
    "models['Stacking Regressor'] = stacking_model\n",
    "models['Voting Regressor'] = voting_model\n",
    "\n",
    "# 存储结果\n",
    "results = []\n",
    "\n",
    "# 进行交叉验证\n",
    "kf = KFold(n_splits=10, shuffle=True, random_state=42)\n",
    "for name, model in models.items():\n",
    "    # 添加标准化管道\n",
    "    pipeline = make_pipeline(StandardScaler(), model)\n",
    "    cv_scores = cross_val_score(pipeline, X_selected, y, cv=kf, scoring='neg_mean_squared_error')\n",
    "    mse = -np.mean(cv_scores)\n",
    "    pipeline.fit(X_selected, y)  # 训练模型以便获取其他指标\n",
    "    y_pred = pipeline.predict(X_selected)\n",
    "    mae = mean_absolute_error(y, y_pred)\n",
    "    rmse = np.sqrt(mse)\n",
    "    r2 = r2_score(y, y_pred)\n",
    "    results.append((name, mse, mae, rmse, r2))\n",
    "\n",
    "# 创建结果DataFrame\n",
    "results_df = pd.DataFrame(results, columns=['Model', 'MSE', 'MAE', 'RMSE', 'R2'])\n",
    "\n",
    "# 输出结果\n",
    "print(results_df)\n"
   ]
  },
